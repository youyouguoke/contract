.page-stamp-manage {
  padding: 24rpx;
  padding-bottom: 60rpx;
}

/* 创建入口 */
.create-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx dashed #4F7CFF;
  background: #ECF2FF;
}

.create-icon {
  font-size: 36rpx;
  color: #4F7CFF;
  font-weight: 600;
}

.create-text {
  font-size: 30rpx;
  color: #4F7CFF;
  font-weight: 500;
}

/* 创建面板 */
.creator-panel {
  margin-bottom: 24rpx;
}

/* 上传区域 */
.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #DCDFE6;
  border-radius: 12rpx;
  background: #FAFAFA;
  padding: 40rpx 0;
  gap: 8rpx;
}

.upload-icon {
  font-size: 56rpx;
  color: #C0C4CC;
  line-height: 1;
}

.upload-text {
  font-size: 28rpx;
  color: #606266;
}

.upload-hint {
  font-size: 22rpx;
  color: #C0C4CC;
}

.uploaded-preview {
  position: relative;
  display: flex;
  justify-content: center;
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 20rpx;
}

.uploaded-img {
  width: 300rpx;
  height: 300rpx;
}

.remove-img {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
}

.field-group {
  margin-bottom: 24rpx;
}

/* 用途选择 */
.purpose-options {
  gap: 12rpx;
}

.purpose-chip {
  font-size: 24rpx;
  color: #606266;
  background: #F5F6FA;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid transparent;
}

.purpose-chip.active {
  color: #C32A2A;
  background: #FEF0F0;
  border-color: #C32A2A;
  font-weight: 500;
}

.field-label {
  font-size: 26rpx;
  color: #606266;
  margin-bottom: 8rpx;
  display: block;
}

.field-input {
  border: 1rpx solid #DCDFE6;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #FAFAFA;
}

/* Canvas 隐藏但需渲染 */
.stamp-canvas-hidden {
  width: 500px;
  height: 500px;
  position: fixed;
  left: -9999px;
  top: 0;
}

.preview-section {
  margin-bottom: 24rpx;
}

.preview-title {
  font-size: 26rpx;
  color: #909399;
  display: block;
  margin-bottom: 16rpx;
}

.stamp-preview-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  min-height: 280rpx;
}

.stamp-preview-img {
  width: 260rpx;
  height: 260rpx;
}

.preview-loading {
  font-size: 24rpx;
  color: #C0C4CC;
}

.preview-note {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #909399;
  margin-top: 12rpx;
}

.creator-btn {
  text-align: center;
  background: #4F7CFF;
  color: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 已保存列表 */
.section-header {
  font-size: 26rpx;
  color: #909399;
  margin-bottom: 16rpx;
}

.empty-tip {
  text-align: center;
  color: #C0C4CC;
  font-size: 26rpx;
  padding: 60rpx 0;
}

.stamp-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stamp-item {
  padding: 24rpx;
}

.stamp-display {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

.stamp-list-img {
  width: 200rpx;
  height: 200rpx;
}

.stamp-footer {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F6FA;
  gap: 16rpx;
}

.stamp-default-badge {
  font-size: 22rpx;
  color: #4F7CFF;
  background: #ECF2FF;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.stamp-type-badge {
  font-size: 20rpx;
  color: #19BE6B;
  background: #E8F8EF;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.stamp-type-badge.gen {
  color: #E6A23C;
  background: #FDF6EC;
}

.stamp-name {
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stamp-action {
  font-size: 26rpx;
  color: #4F7CFF;
  padding: 8rpx 16rpx;
}

.stamp-action.delete {
  color: #FA3534;
}
