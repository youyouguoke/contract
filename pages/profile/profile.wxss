.page-profile {
  padding-bottom: 120rpx;
}

/* 头部 */
.profile-header {
  margin-bottom: -32rpx;
}

.header-bg {
  background: linear-gradient(135deg, #4F7CFF 0%, #6E8EFF 100%);
  padding: 60rpx 32rpx 64rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.avatar-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  overflow: hidden;
}

.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.avatar-text {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
}

.user-phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
  display: block;
}

.login-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
}

.login-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
  display: block;
}

.login-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 统计 */
.stats-bar {
  margin: 24rpx 24rpx 0;
  position: relative;
  z-index: 1;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #909399;
  margin-top: 4rpx;
}

/* 菜单 */
.menu-group {
  margin: 24rpx 24rpx 0;
  padding: 0;
}

.menu-item {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F5F6FA;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-badge {
  font-size: 22rpx;
  color: #E6A23C;
  background: #FDF6EC;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #C0C4CC;
}

/* button 样式重置（用于 open-type="contact"） */
.menu-item-btn {
  width: 100%;
  background: none;
  border: none;
  border-radius: 0;
  margin: 0;
  padding: 28rpx 32rpx;
  font-size: inherit;
  line-height: inherit;
  text-align: left;
  box-sizing: border-box;
  border-bottom: 1rpx solid #F5F6FA;
  justify-content: flex-start;
}

.menu-item-btn::after {
  border: none;
}

/* 退出 */
.logout-section {
  padding: 48rpx;
}

.logout-btn {
  background: #FFFFFF;
  color: #FA3534;
  border: 1rpx solid #FA3534;
  border-radius: 12rpx;
  font-size: 30rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0;
  padding: 0;
}

.logout-btn::after {
  border: none;
}

/* 编辑资料弹窗 */
.profile-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.profile-editor {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 48rpx 120rpx;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 80vh;
  box-sizing: border-box;
}

.profile-editor.show {
  transform: translateY(0);
}

.editor-header {
  margin-bottom: 40rpx;
}

.editor-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.editor-close {
  font-size: 36rpx;
  color: #C0C4CC;
  padding: 10rpx;
}

.editor-avatar-section {
  margin-bottom: 40rpx;
}

.editor-avatar-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #F5F6FA;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.editor-avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
}

.editor-avatar-text {
  font-size: 56rpx;
  color: #4F7CFF;
  font-weight: 600;
}

.editor-avatar-hint {
  font-size: 24rpx;
  color: #909399;
}

.editor-nick-section {
  margin-bottom: 40rpx;
}

.editor-nick-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.editor-nick-input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #DCDFE6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.editor-save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 12rpx;
}
