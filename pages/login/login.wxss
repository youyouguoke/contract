.page-login {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 0 48rpx;
}

.login-header {
  padding-top: 160rpx;
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-wrap {
  margin-bottom: 20rpx;
}

.logo-text {
  font-size: 56rpx;
  font-weight: 700;
  color: #4F7CFF;
  letter-spacing: 4rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #909399;
}

.login-body {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-body .wx-login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  border-radius: 16rpx;
  margin: 0;
  padding: 0;
}

.agreement-section {
  margin-top: 48rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #909399;
}

.agreement-link {
  font-size: 24rpx;
}
