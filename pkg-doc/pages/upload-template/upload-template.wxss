.page-upload {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

/* 上传区域 */
.upload-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  border: 3rpx dashed #DCDFE6;
  background: #FAFBFC;
}

.upload-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #ECF2FF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.upload-icon {
  font-size: 56rpx;
}

.upload-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.upload-desc {
  font-size: 24rpx;
  color: #909399;
  text-align: center;
}

/* 文件卡片 */
.file-card {
  padding: 28rpx 32rpx;
}

.file-type-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 20rpx;
  color: #FFFFFF;
}

.file-type-icon.pdf {
  background: #FA3534;
}

.file-type-icon.word {
  background: #4F7CFF;
}

.file-meta {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.file-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.file-size {
  font-size: 24rpx;
  color: #909399;
  margin-top: 4rpx;
}

.file-remove {
  font-size: 32rpx;
  color: #C0C4CC;
  padding: 8rpx 0 8rpx 16rpx;
}

/* 进度条 */
.progress-section {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #EBEEF5;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4F7CFF, #6E8EFF);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #4F7CFF;
  white-space: nowrap;
  min-width: 80rpx;
  text-align: right;
}

.error-section {
  margin-top: 16rpx;
}

.error-text {
  font-size: 24rpx;
  color: #FA3534;
}

/* 表单 */
.field-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.field-input {
  border: 1rpx solid #DCDFE6;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #FAFAFA;
}

/* 文档解析状态 (PDF) */
.convert-section {
  padding: 28rpx 32rpx;
}

.convert-loading {
  gap: 16rpx;
  padding: 16rpx 0;
}

.convert-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #EBEEF5;
  border-top-color: #4F7CFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.convert-result {
  gap: 12rpx;
  padding: 16rpx 0;
}

.convert-icon-ok,
.convert-icon-err {
  font-size: 32rpx;
}

.convert-text {
  font-size: 28rpx;
  color: #606266;
}

.convert-text.error {
  color: #FA3534;
}

.convert-error {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.retry-btn {
  font-size: 26rpx;
  color: #4F7CFF;
  padding: 8rpx 24rpx;
  border: 1rpx solid #4F7CFF;
  border-radius: 8rpx;
}

/* 页数选择 (Word) */
.page-count-row {
  gap: 40rpx;
  padding: 16rpx 0;
}

.count-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #F5F6FA;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
}

.count-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #4F7CFF;
  min-width: 60rpx;
  text-align: center;
}

.count-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #C0C4CC;
  margin-top: 8rpx;
}

/* 底部 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 16rpx 32rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.disabled {
  opacity: 0.5;
}
