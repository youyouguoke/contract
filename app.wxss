/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  background-color: #F5F6FA;
  line-height: 1.6;
}

/* 主题色变量 */
.primary-color { color: #4F7CFF; }
.primary-bg { background-color: #4F7CFF; }
.success-color { color: #19BE6B; }
.warning-color { color: #FF9900; }
.danger-color { color: #FA3534; }
.info-color { color: #909399; }

/* 通用容器 */
.container {
  padding: 24rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 按钮 */
.btn-primary,
.btn-outline {
  margin: 0;
  padding: 0;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 12rpx;
}

.btn-primary {
  background-color: #4F7CFF;
  color: #FFFFFF;
  border: none;
}

.btn-primary::after { border: none; }

.btn-outline {
  background-color: transparent;
  color: #4F7CFF;
  border: 2rpx solid #4F7CFF;
}

.btn-outline::after { border: none; }

/* 文字截断 */
.text-ellipsis {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* flex 布局 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.flex-1 { flex: 1; }

/* 间距 */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.ml-16 { margin-left: 16rpx; }
.mr-16 { margin-right: 16rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #EBEEF5;
  margin: 24rpx 0;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
