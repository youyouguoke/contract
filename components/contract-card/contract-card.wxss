.contract-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  max-width: 480rpx;
}

.status-badge {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

/* 标签 */
.card-tags {
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.card-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  white-space: nowrap;
}

.card-body {
  margin-bottom: 20rpx;
}

.info-row {
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.info-row .label {
  color: #909399;
  width: 120rpx;
}

.info-row .value {
  color: #606266;
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.card-footer {
  border-top: 1rpx solid #EBEEF5;
  padding-top: 20rpx;
}

.card-footer .time {
  font-size: 24rpx;
  color: #C0C4CC;
}

.card-footer .action {
  font-size: 26rpx;
}
