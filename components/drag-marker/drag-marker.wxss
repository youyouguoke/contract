.marker {
  display: flex;
  align-items: center;
  width: 100%;
  height: 100%;
  border: 2rpx dashed;
  border-radius: 8rpx;
  padding: 0 10rpx;
  box-sizing: border-box;
  position: relative;
  opacity: 0.85;
  transition: opacity 0.2s;
}

.marker-selected {
  opacity: 1;
  border-style: solid;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15);
}

/* 默认类型颜色（会被 signerColor 行内样式覆盖） */
.marker-signature {
  border-color: #4F7CFF;
  background: rgba(79, 124, 255, 0.12);
}

.marker-stamp {
  border-color: #FA3534;
  background: rgba(250, 53, 52, 0.10);
}

.marker-date {
  border-color: #19BE6B;
  background: rgba(25, 190, 107, 0.12);
}

/* 签署方标签 */
.marker-signer {
  position: absolute;
  top: -20rpx;
  left: 6rpx;
  font-size: 18rpx;
  padding: 0 8rpx;
  border-radius: 4rpx;
  line-height: 28rpx;
  font-weight: 500;
  white-space: nowrap;
}

.marker-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
  flex-shrink: 0;
}

.marker-label {
  font-size: 20rpx;
  font-weight: 500;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.marker-signature .marker-label { color: #4F7CFF; }
.marker-stamp .marker-label { color: #FA3534; }
.marker-date .marker-label { color: #19BE6B; }

.marker-delete {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 20rpx;
  color: #FFFFFF;
  background: #FA3534;
  border-radius: 50%;
  z-index: 10;
}
