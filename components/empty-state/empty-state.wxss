.empty-state {
  padding: 120rpx 60rpx;
}

.empty-icon-wrap {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-doc {
  position: relative;
  width: 120rpx;
  height: 150rpx;
  background: #EBEEF5;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.empty-doc-fold {
  position: absolute;
  top: 0;
  right: 0;
  width: 0;
  height: 0;
  border-left: 30rpx solid #FFFFFF;
  border-bottom: 30rpx solid #DCDFE6;
}

.empty-doc-line {
  width: 100%;
  height: 6rpx;
  background: #DCDFE6;
  border-radius: 3rpx;
}

.empty-doc-line.short {
  width: 60%;
}

.empty-text {
  font-size: 28rpx;
  color: #909399;
  margin-bottom: 40rpx;
}

.empty-btn {
  width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  margin: 0;
  padding: 0;
}
